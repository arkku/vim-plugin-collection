#!/usr/bin/env bash
#
# remove-obsolete-submodules
#
# Find submodules that exist locally (in .git/config sections or
# .git/modules/ metadata dirs, or as on-disk gitlinked directories) but
# are no longer listed in .gitmodules, and clean them up:
#
# Dry-run by default. Pass --yes (or -y) to actually delete.
#
# This is script was generated by AI, provided only for convenience.
# Use at your own risk only!

set -eu

DRY_RUN=1
case "${1:-}" in
    -y|--yes)     DRY_RUN=0 ;;
    -n|--dry-run) DRY_RUN=1 ;;
    -h|--help)
        cat <<EOF
Usage: $(basename "$0") [--yes|--dry-run]

Removes submodules registered locally that are no longer in .gitmodules.
Default is to dry-run; use --yes to apply changes.
EOF
        exit 0
        ;;
    '') ;;
    *) echo "Unknown argument: $1" >&2; exit 2 ;;
esac

cd "$(git rev-parse --show-toplevel)"

run() {
    if [ "$DRY_RUN" -eq 1 ]; then
        printf '%s\n' "$*"
    else
        printf '+ %s\n' "$*"
        "$@"
    fi
}

# --- Names currently registered in .gitmodules
registered_file=$(mktemp)
trap 'rm -f "$registered_file" "$candidates_file"' EXIT

if [ -f .gitmodules ]; then
    git config -f .gitmodules --name-only --get-regexp '^submodule\..*\.path$' \
        | sed -E 's/^submodule\.(.*)\.path$/\1/' \
        | sort -u > "$registered_file"
fi

is_registered() {
    grep -Fxq -- "$1" "$registered_file" 2>/dev/null
}

# --- Collect candidate orphan paths from .git/config and .git/modules
candidates_file=$(mktemp)
: > "$candidates_file"

# From .git/config: any [submodule "name"] section
git config --name-only --get-regexp '^submodule\..*\.url$' 2>/dev/null \
    | sed -E 's/^submodule\.(.*)\.url$/\1/' \
    >> "$candidates_file" || true

# From .git/modules: any directory containing a `config` file is a submodule
# metadata dir. Path-name equals the submodule path.
if [ -d .git/modules ]; then
    find .git/modules -type f -name config \
        | sed -E 's|^\.git/modules/(.*)/config$|\1|' \
        >> "$candidates_file"
fi

orphans=$(sort -u "$candidates_file" | while IFS= read -r name; do
    [ -n "$name" ] || continue
    # Skip nested submodule metadata: a `.git/modules/<parent>/modules/<child>`
    # path describes a child owned by its parent. Touching it directly would
    # corrupt the parent's bookkeeping; it's cleaned up via the parent.
    case "$name" in
        (*/modules/*) continue ;;
    esac
    is_registered "$name" || printf '%s\n' "$name"
done)

if [ -z "$orphans" ]; then
    echo "No obsolete submodules found."
    exit 0
fi

if [ "$DRY_RUN" -eq 1 ]; then
    echo "(dry run — pass --yes to apply)"
    echo
fi

printf '%s\n' "$orphans" | while IFS= read -r path; do
    [ -n "$path" ] || continue
    # Identify what this orphan was, so the report is recognisable.
    url=$(git config --get "submodule.$path.url" 2>/dev/null \
        || git config -f ".git/modules/$path/config" --get remote.origin.url 2>/dev/null \
        || echo "(unknown remote)")

    note=""
    if [ -n "$url" ] && [ -f .gitmodules ] \
       && git config -f .gitmodules --get-regexp '^submodule\..*\.url$' 2>/dev/null \
            | awk '{print $2}' | grep -Fxq "$url"; then
        live_path=$(git config -f .gitmodules --get-regexp '^submodule\..*\.url$' \
            | awk -v u="$url" '$2==u {print $1; exit}' \
            | sed -E 's/^submodule\.(.*)\.url$/\1/')
        note=" — renamed to '$live_path'"
    fi

    echo "# Obsolete: $path"
    echo "#   remote: $url$note"

    if git config --get "submodule.$path.url" >/dev/null 2>&1; then
        run git submodule deinit -f -- "$path" || true
    fi

    if [ -e "$path" ]; then
        run rm -rf -- "$path"
    fi

    if [ -d ".git/modules/$path" ]; then
        run rm -rf -- ".git/modules/$path"
    fi

    if git config --get-regexp "^submodule\." 2>/dev/null \
        | awk '{print $1}' | grep -Fxq "submodule.$path.url"; then
        run git config --remove-section "submodule.$path"
    fi

    echo ''
done
